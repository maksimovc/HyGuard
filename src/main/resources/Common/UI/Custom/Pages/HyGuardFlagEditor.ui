$C = "../Common.ui";
$Hg = "HyGuardShared.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 1120, Height: 760);
    Background: $Hg.@HgPanelBackground;

    Button #BackButton {
      Anchor: (Top: 24, Left: 28, Width: 102, Height: 42);
      Style: $Hg.@HgSecondaryButtonStyle;
      Label { Text: "Назад"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
    }

    Label #PageTitle {
      Text: "Flag Editor";
      Style: $Hg.@HgTitleStyle;
      Anchor: (Top: 28, Left: 148, Right: 148, Height: 26);
    }

    Label #Subtitle {
      Style: $Hg.@HgMetaStyle;
      Anchor: (Top: 58, Left: 148, Right: 148, Height: 32);
    }

    Button #CloseIconButton {
      Anchor: (Top: 24, Right: 28, Width: 42, Height: 42);
      Style: $Hg.@HgSecondaryButtonStyle;
      Label { Text: "X"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
    }

    Group #StatusCard {
      Anchor: (Top: 108, Left: 28, Right: 28, Height: 54);
      Background: $Hg.@HgSurface;
      Padding: (Top: 12, Bottom: 12, Left: 18, Right: 18);

      Group #StatusInfo { Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8); Background: $Hg.@HgPrimary; Visible: false; }
      Group #StatusSuccess { Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8); Background: $Hg.@HgPositive; Visible: false; }
      Group #StatusWarning { Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8); Background: $Hg.@HgDangerHover; Visible: false; }
      Group #StatusError { Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8); Background: $Hg.@HgDanger; Visible: false; }

      Label #StatusText { Style: $Hg.@HgBodyStyle; Anchor: (Top: 12, Left: 18, Right: 0, Height: 18); }
    }

    Group #ToolbarCard {
      Anchor: (Top: 180, Left: 28, Right: 28, Height: 84);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

      Button #CategoryBlocksButton {
        Anchor: (Top: 0, Left: 0, Width: 100, Height: 40);
        Style: $Hg.@HgTabButtonStyle;
        Label { Text: "Блоки"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
        Group #CategoryBlocksSelected { Anchor: (Left: 10, Right: 10, Bottom: 4, Height: 4); Background: $Hg.@HgPrimary; Visible: false; }
      }

      Button #CategoryPlayersButton {
        Anchor: (Top: 0, Left: 112, Width: 100, Height: 40);
        Style: $Hg.@HgTabButtonStyle;
        Label { Text: "Гравці"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
        Group #CategoryPlayersSelected { Anchor: (Left: 10, Right: 10, Bottom: 4, Height: 4); Background: $Hg.@HgPrimary; Visible: false; }
      }

      Button #CategoryMobsButton {
        Anchor: (Top: 0, Left: 224, Width: 100, Height: 40);
        Style: $Hg.@HgTabButtonStyle;
        Label { Text: "Моби"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
        Group #CategoryMobsSelected { Anchor: (Left: 10, Right: 10, Bottom: 4, Height: 4); Background: $Hg.@HgPrimary; Visible: false; }
      }

      Button #CategoryEnvironmentButton {
        Anchor: (Top: 0, Left: 336, Width: 120, Height: 40);
        Style: $Hg.@HgTabButtonStyle;
        Label { Text: "Середовище"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
        Group #CategoryEnvironmentSelected { Anchor: (Left: 10, Right: 10, Bottom: 4, Height: 4); Background: $Hg.@HgPrimary; Visible: false; }
      }

      Button #CategoryEntryExitButton {
        Anchor: (Top: 0, Left: 468, Width: 120, Height: 40);
        Style: $Hg.@HgTabButtonStyle;
        Label { Text: "Вхід / вихід"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
        Group #CategoryEntryExitSelected { Anchor: (Left: 10, Right: 10, Bottom: 4, Height: 4); Background: $Hg.@HgPrimary; Visible: false; }
      }

      Button #CategorySpecialButton {
        Anchor: (Top: 0, Left: 600, Width: 100, Height: 40);
        Style: $Hg.@HgTabButtonStyle;
        Label { Text: "Особливе"; Style: $Hg.@HgButtonLabelStyle; Anchor: (Full: 0); }
        Group #CategorySpecialSelected { Anchor: (Left: 10, Right: 10, Bottom: 4, Height: 4); Background: $Hg.@HgPrimary; Visible: false; }
      }

      Group {
        Anchor: (Top: 0, Right: 0, Width: 240, Height: 40);
        Background: $Hg.@HgInputBackground;
        OutlineColor: $Hg.@HgOutline;
        OutlineSize: 1;
        Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);

        TextField #SearchInput {
          Anchor: (Full: 0);
          Style: $Hg.@HgInputStyle;
          PlaceholderText: "Пошук правил";
          PlaceholderStyle: $C.@DefaultInputFieldPlaceholderStyle;
        }
      }
    }

    Group #ContentCard {
      Anchor: (Top: 280, Left: 28, Right: 28, Bottom: 28);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

      Group #FlagScrollArea {
        Anchor: (Top: 0, Left: 0, Right: 0, Bottom: 0);
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #FlagRowsGroup {
          LayoutMode: Top;
        }
      }
    }
  }
}