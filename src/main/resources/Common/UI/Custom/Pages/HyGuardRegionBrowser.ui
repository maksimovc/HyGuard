$C = "../Common.ui";
$Hg = "HyGuardShared.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 1120, Height: 760);
    Background: $Hg.@HgPanelBackground;

    Button #BackButton {
      Anchor: (Top: 24, Left: 28, Width: 102, Height: 42);
      Style: $Hg.@HgSecondaryButtonStyle;
      Visible: false;

      Label {
        Text: "Back";
        Style: $Hg.@HgButtonLabelStyle;
        Anchor: (Full: 0);
      }
    }

    Label {
      Text: "HyGuard";
      Style: $Hg.@HgTitleStyle;
      Anchor: (Top: 28, Left: 148, Height: 26);
    }

    Label #PageTitle {
      Style: $Hg.@HgMetaStyle;
      Anchor: (Top: 60, Left: 148, Right: 90, Height: 18);
    }

    Button #CloseIconButton {
      Anchor: (Top: 24, Right: 28, Width: 42, Height: 42);
      Style: $Hg.@HgSecondaryButtonStyle;

      Label {
        Text: "X";
        Style: $Hg.@HgButtonLabelStyle;
        Anchor: (Full: 0);
      }
    }

    Group #SummaryCard {
      Anchor: (Top: 96, Left: 28, Right: 28, Height: 86);
      Background: $Hg.@HgSurface;
      Padding: (Top: 12, Bottom: 12, Left: 18, Right: 18);

      Group {
        Anchor: (Top: 0, Left: 0, Width: 250, Height: 62);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
        Label { Text: "Світ"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #WorldValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 22, Left: 0, Right: 0, Height: 18); }
      }

      Group {
        Anchor: (Top: 0, Left: 264, Width: 160, Height: 62);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
        Label { Text: "Регіони"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #CountValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 22, Left: 0, Right: 0, Height: 18); }
      }

      Group {
        Anchor: (Top: 0, Left: 438, Right: 0, Height: 62);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
        Label { Text: "Фокус"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #HelpText { Style: $Hg.@HgMetaStyle; Anchor: (Top: 22, Left: 0, Right: 0, Height: 18); }
      }
    }

    Group {
      Anchor: (Top: 198, Left: 28, Right: 28, Bottom: 28);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 12, Right: 12);

      Label {
        Text: "Список";
        Style: $Hg.@HgSectionTitleStyle;
        Anchor: (Top: 0, Left: 6, Width: 120, Height: 18);
      }

      Group #RowsContainer {
        Anchor: (Top: 28, Left: 0, Right: 0, Bottom: 0);
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #RegionGroup {
          LayoutMode: Top;
        }
      }
    }
  }
}