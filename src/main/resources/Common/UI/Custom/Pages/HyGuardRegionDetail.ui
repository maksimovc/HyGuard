$C = "../Common.ui";
$Hg = "HyGuardShared.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 1040, Height: 760);
    Background: $Hg.@HgPanelBackground;

    TextButton #BackButton {
      Anchor: (Top: 24, Left: 28, Width: 102, Height: 42);
      Text: "Back";
      Style: $Hg.@HgSecondaryTextButtonStyle;
    }

    Label {
      Text: "HyGuard Region";
      Style: $Hg.@HgMetaStyle;
      Anchor: (Top: 28, Left: 150, Height: 18);
    }

    Label #PageTitle {
      Style: $Hg.@HgTitleStyle;
      Anchor: (Top: 48, Left: 150, Right: 150, Height: 26);
    }

    Label #PageSubtitle {
      Style: $Hg.@HgMetaStyle;
      Anchor: (Top: 78, Left: 150, Right: 150, Height: 18);
    }

    TextButton #CloseIconButton {
      Anchor: (Top: 24, Right: 28, Width: 42, Height: 42);
      Text: "X";
      Style: $Hg.@HgSecondaryTextButtonStyle;
    }

    Group #StatusCard {
      Anchor: (Top: 114, Left: 28, Right: 28, Height: 60);
      Background: $Hg.@HgSurface;
      Padding: (Top: 12, Bottom: 12, Left: 18, Right: 18);

      Group #StatusInfo {
        Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8);
        Background: $Hg.@HgPrimary;
        Visible: false;
      }

      Group #StatusSuccess {
        Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8);
        Background: $Hg.@HgPositive;
        Visible: false;
      }

      Group #StatusWarning {
        Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8);
        Background: $Hg.@HgDangerHover;
        Visible: false;
      }

      Group #StatusError {
        Anchor: (Top: 8, Left: 0, Width: 6, Bottom: 8);
        Background: $Hg.@HgDanger;
        Visible: false;
      }

      Label {
        Text: "Status";
        Style: $Hg.@HgSectionTitleStyle;
        Anchor: (Top: 0, Left: 18, Width: 80, Height: 16);
      }

      Label #StatusText {
        Style: $Hg.@HgBodyStyle;
        Anchor: (Top: 22, Left: 18, Right: 0, Height: 18);
      }
    }

    Group #SummaryCard {
      Anchor: (Top: 190, Left: 28, Right: 28, Height: 100);
      Background: $Hg.@HgSurface;
      Padding: (Top: 14, Bottom: 14, Left: 18, Right: 18);

      Group {
        Anchor: (Top: 0, Left: 0, Width: 180, Height: 72);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        Label { Text: "Owner"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #SummaryOwner { Style: $Hg.@HgBodyStyle; Anchor: (Top: 24, Left: 0, Right: 0, Height: 18); }
      }

      Group {
        Anchor: (Top: 0, Left: 194, Width: 140, Height: 72);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        Label { Text: "Priority"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #SummaryPriority { Style: $Hg.@HgBodyStyle; Anchor: (Top: 24, Left: 0, Right: 0, Height: 18); }
      }

      Group {
        Anchor: (Top: 0, Left: 348, Width: 140, Height: 72);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        Label { Text: "Members"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #SummaryMembers { Style: $Hg.@HgBodyStyle; Anchor: (Top: 24, Left: 0, Right: 0, Height: 18); }
      }

      Group {
        Anchor: (Top: 0, Left: 502, Width: 220, Height: 72);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        Label { Text: "Parent"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #SummaryParent { Style: $Hg.@HgBodyStyle; Anchor: (Top: 24, Left: 0, Right: 0, Height: 18); }
      }

      Group {
        Anchor: (Top: 0, Right: 0, Width: 160, Height: 72);
        Background: $Hg.@HgSurfaceAlt;
        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
        Label { Text: "Spawn"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 0, Left: 0, Right: 0, Height: 14); }
        Label #SummarySpawn { Style: $Hg.@HgBodyStyle; Anchor: (Top: 24, Left: 0, Right: 0, Height: 18); }
      }
    }

    Group #Details {
      Anchor: (Top: 308, Left: 28, Width: 494, Height: 250);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

      Label { Text: "Details"; Style: $Hg.@HgSectionTitleStyle; Anchor: (Top: 0, Left: 0, Width: 120, Height: 18); }

      Label { Text: "Name"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 34, Left: 0, Width: 84, Height: 16); }
      Label #NameValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 54, Left: 0, Right: 0, Height: 18); }

      Label { Text: "Owner"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 84, Left: 0, Width: 84, Height: 16); }
      Label #OwnerValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 104, Left: 0, Right: 0, Height: 18); }

      Label { Text: "World"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 134, Left: 0, Width: 84, Height: 16); }
      Label #WorldValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 154, Left: 0, Right: 0, Height: 18); }

      Label { Text: "Spawn"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 184, Left: 0, Width: 84, Height: 16); }
      Label #SpawnValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 204, Left: 0, Right: 0, Height: 18); }
    }

    Group #BoundsCard {
      Anchor: (Top: 308, Left: 538, Right: 28, Height: 250);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

      Label { Text: "Bounds & Hierarchy"; Style: $Hg.@HgSectionTitleStyle; Anchor: (Top: 0, Left: 0, Width: 180, Height: 18); }

      Label { Text: "Bounds"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 34, Left: 0, Width: 90, Height: 16); }
      Label #BoundsValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 54, Left: 0, Right: 0, Height: 54); }

      Label { Text: "Members"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 122, Left: 0, Width: 90, Height: 16); }
      Label #MembersValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 142, Left: 0, Width: 100, Height: 18); }

      Label { Text: "Priority"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 122, Left: 132, Width: 90, Height: 16); }
      Label #PriorityValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 142, Left: 132, Width: 100, Height: 18); }

      Label { Text: "Hierarchy"; Style: $Hg.@HgFieldLabelStyle; Anchor: (Top: 176, Left: 0, Width: 90, Height: 16); }
      Label #HierarchyValue { Style: $Hg.@HgBodyStyle; Anchor: (Top: 196, Left: 0, Right: 0, Height: 34); }
    }

    Group #WorkCard {
      Anchor: (Top: 576, Left: 28, Width: 494, Height: 156);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

      Label { Text: "Region Work"; Style: $Hg.@HgSectionTitleStyle; Anchor: (Top: 0, Left: 0, Width: 120, Height: 18); }
      Label { Text: "Teleport, load the selection, or store your current location as the region spawn."; Style: $Hg.@HgMetaStyle; Anchor: (Top: 20, Left: 0, Right: 0, Height: 28); }

      TextButton #TeleportButton {
        Anchor: (Top: 70, Left: 0, Width: 138, Height: 42);
        Text: "Teleport";
        Style: $Hg.@HgPrimaryTextButtonStyle;
      }

      Group #TeleportButtonDisabled {
        Anchor: (Top: 70, Left: 0, Width: 138, Height: 42);
        Background: $Hg.@HgSurfaceDisabled;
        Visible: false;
        Label { Text: "Teleport locked"; Style: $Hg.@HgButtonLabelDisabledStyle; Anchor: (Full: 0); }
      }

      TextButton #SelectButton {
        Anchor: (Top: 70, Left: 156, Width: 146, Height: 42);
        Text: "Load Selection";
        Style: $Hg.@HgSecondaryTextButtonStyle;
      }

      Group #SelectButtonDisabled {
        Anchor: (Top: 70, Left: 156, Width: 146, Height: 42);
        Background: $Hg.@HgSurfaceDisabled;
        Visible: false;
        Label { Text: "Selection locked"; Style: $Hg.@HgButtonLabelDisabledStyle; Anchor: (Full: 0); }
      }

      TextButton #SetSpawnButton {
        Anchor: (Top: 70, Left: 320, Width: 138, Height: 42);
        Text: "Set Spawn";
        Style: $Hg.@HgSecondaryTextButtonStyle;
      }

      Group #SetSpawnButtonDisabled {
        Anchor: (Top: 70, Left: 320, Width: 138, Height: 42);
        Background: $Hg.@HgSurfaceDisabled;
        Visible: false;
        Label { Text: "Spawn locked"; Style: $Hg.@HgButtonLabelDisabledStyle; Anchor: (Full: 0); }
      }
    }

    Group #ManagementCard {
      Anchor: (Top: 576, Left: 538, Width: 280, Height: 156);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

      Label { Text: "Management"; Style: $Hg.@HgSectionTitleStyle; Anchor: (Top: 0, Left: 0, Width: 120, Height: 18); }
      Label { Text: "Open the dedicated screens for members and flags."; Style: $Hg.@HgMetaStyle; Anchor: (Top: 20, Left: 0, Right: 0, Height: 28); }

      TextButton #MembersButton {
        Anchor: (Top: 70, Left: 0, Width: 114, Height: 42);
        Text: "Members";
        Style: $Hg.@HgSecondaryTextButtonStyle;
      }

      TextButton #FlagsButton {
        Anchor: (Top: 70, Left: 130, Width: 114, Height: 42);
        Text: "Flags";
        Style: $Hg.@HgSecondaryTextButtonStyle;
      }
    }

    Group #DangerCard {
      Anchor: (Top: 576, Left: 834, Right: 28, Height: 156);
      Background: $Hg.@HgSurface;
      Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

      Label { Text: "Danger Zone"; Style: $Hg.@HgSectionTitleStyle; Anchor: (Top: 0, Left: 0, Width: 120, Height: 18); }
      Label { Text: "Deletion is separated from regular actions to reduce accidental clicks."; Style: $Hg.@HgMetaStyle; Anchor: (Top: 20, Left: 0, Right: 0, Height: 28); }

      TextButton #DeleteButton {
        Anchor: (Top: 70, Left: 0, Right: 0, Height: 42);
        Text: "Delete Region";
        Style: $Hg.@HgDangerTextButtonStyle;
      }

      Group #DeleteButtonDisabled {
        Anchor: (Top: 70, Left: 0, Right: 0, Height: 42);
        Background: $Hg.@HgSurfaceDisabled;
        Visible: false;
        Label { Text: "Delete locked"; Style: $Hg.@HgButtonLabelDisabledStyle; Anchor: (Full: 0); }
      }

      Label #DeleteHint {
        Style: $Hg.@HgMetaStyle;
        Anchor: (Top: 120, Left: 0, Right: 0, Height: 24);
      }
    }
  }
}